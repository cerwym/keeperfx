{
    "configurations": [
        {
            // IntelliSense for Windows x86 desktop build (cross-compiled via Docker mingw32).
            // Run "Generate compile_commands.json" task first to populate the database.
            // compile_commands.json is written to the build dir by CMake's EXPORT_COMPILE_COMMANDS.
            "name": "Docker MinGW (Windows x86 Debug)",
            "compileCommands": "${workspaceFolder}/out/build/windows-x86-debug/compile_commands.json",
            "cStandard": "gnu11",
            "cppStandard": "gnu++17",
            "intelliSenseMode": "windows-gcc-x86"
        }
    ],
    "version": 4
}
