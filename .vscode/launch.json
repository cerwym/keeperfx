// KeeperFX Launch Configuration (Template)
// Auto-generated by onboarding script on folder open
//
// Debugging: Uses local GDB (.vscode/gdb.exe, MinGW i686 build)
// Requires DEBUG=1 in compile_settings.cfg
{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Compile, Copy Files, Launch keeperfx.exe",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/.deploy/keeperfx.exe",
            "cwd": "${workspaceFolder}/.deploy",
            "args": [
                "-level", "00001",
                "-campaign", "keeporig",
                "-nointro", "-alex"
            ],
            "windows": {
                "miDebuggerPath": "${workspaceFolder}/.vscode/gdb.exe"
            },
            "linux": {
                "miDebuggerPath": "winegdb"
            },
            "setupCommands": [
                {"description": "Enable pretty-printing for gdb", "text": "-enable-pretty-printing", "ignoreFailures": true},
                {"description": "Set Disassembly Flavor to Intel", "text": "-gdb-set disassembly-flavor intel", "ignoreFailures": true}
            ],
            "sourceFileMap": { "/mnt/c/": "C:/" },
            "MIMode": "gdb",
            "preLaunchTask": "Compile, Copy Files",
            "postDebugTask": "Show Log Contents",
            "externalConsole": true,
            "stopAtEntry": false,
            "internalConsoleOptions": "openOnSessionStart",
            "logging": {
                "moduleLoad": false
            }
        }
    ]
}
